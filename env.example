# 📧 Variables de Entorno - Portfolio David

# =============================================================================
# 🔧 VARIABLES OBLIGATORIAS (Gmail)
# =============================================================================

# Tu email de Gmail
GMAIL_USER=tu-email@gmail.com

# App Password de Gmail (16 caracteres)
# Generar en: myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=tu-app-password-de-16-caracteres

# Email destinatario (opcional - por defecto usa GMAIL_USER)
RECIPIENT_EMAIL=tu-email@gmail.com

# =============================================================================
# 📊 VARIABLES OPCIONALES
# =============================================================================

# Google Analytics ID (opcional)
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Entorno de desarrollo/producción
NODE_ENV=development

# =============================================================================
# 📝 CONFIGURACIÓN
# =============================================================================

# 1. Copia este archivo: cp env.example .env
# 2. Configura Gmail: Habilitar verificación en 2 pasos y generar App Password
# 3. Configura Vercel: Variables de entorno en Dashboard
# 4. Opcional: Configura Google Analytics

# =============================================================================
# 🔒 SEGURIDAD
# =============================================================================

# ⚠️  IMPORTANTE:
# - NUNCA subas .env a GitHub
# - Usa App Passwords, NO tu contraseña normal de Gmail
# - Configura las variables en Vercel para producción 