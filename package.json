{
  "name": "portfolio-david",
  "version": "2.0.0",
  "private": true,
  "description": "Portfolio de David con arquitectura ports and adapters",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"npm run dev -w @portfolio/api\" \"npm run dev -w @portfolio/web\"",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0"
  }
}
