{
  "name": "david-fernandez-cuenca-portfolio",
  "version": "1.0.0",
  "description": "David Fernández-Cuenca Marcos - Software Engineer Portfolio",
  "main": "index.html",
  "scripts": {
    "dev": "npm run build:css && npx serve . -p 3000",
    "build": "npm run build:css && echo 'Build completed - Static site ready for deployment'",
    "build:css": "npx tailwindcss -i ./src/globals.css -o ./dist/output.css --minify",
    "watch:css": "npx tailwindcss -i ./src/globals.css -o ./dist/output.css --watch",
    "start": "npx serve . -p 3000",
    "preview": "npx serve . -p 3000",
    "lint": "npx eslint src/**/*.{js,jsx} --fix",
    "type-check": "npx tsc --noEmit",
    "format": "npx prettier --write src/**/*.{js,jsx,json,md,css}"
  },
  "keywords": [
    "portfolio",
    "react",
    "software-engineer",
    "air-traffic-control",
    "indra",
    "typescript",
    "tailwind"
  ],
  "author": "David Fernández-Cuenca Marcos",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.5.6",
    "prettier": "^3.0.0",
    "serve": "^14.2.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
