# Build cache
.vercel/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies
node_modules/

# Frontend specific ignores  
frontend/node_modules/
frontend/.vercel/
frontend/dist/

# API specific ignores
api/node_modules/
api/.vercel/

# OS generated files
.DS_Store
.idea/
.vscode/

# Git
.git/
.gitignore

# Temporary files
*.tmp
*.swp
*~

# Testing
coverage/
.nyc_output/

# Build outputs that should be generated fresh
frontend/dist/output.css

# Generated icons (they will be created during build)
frontend/assets/*.png
frontend/assets/*.ico
frontend/site.webmanifest

# Development-specific files
frontend/src/mock-data.js
frontend/generate-icons.js

# Database backups/dumps
*.sql.bak
*.dump