# Vercel ignore file for frontend

# Development files
src/
generate-icons.js
postcss.config.js
tailwind.config.js

# Source files that aren't needed in deployment
*.md
.gitignore
.vercelignore

# Node modules (handled by Vercel)
node_modules/

# Build tools output that gets regenerated
.pnpm-debug.log*

# Only deploy the built/generated files
# Keep: index.html, admin.html, dist/, assets/ (generated icons), site.webmanifest
