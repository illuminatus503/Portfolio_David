{
  "name": "portfolio-frontend",
  "version": "1.0.0",
  "description": "Frontend del Portfolio de David Fernández-Cuenca",
  "private": true,
  "scripts": {
    "dev": "pnpm run build:icons && pnpm run build:css && npx serve . -p 3000",
    "build": "pnpm run build:icons && pnpm run build:css && echo 'Frontend build completed'",
    "build:css": "npx tailwindcss -i ./src/globals.css -o ./dist/output.css --minify",
    "build:icons": "node generate-icons.js",
    "watch:css": "npx tailwindcss -i ./src/globals.css -o ./dist/output.css --watch",
    "start": "npx serve . -p 3000",
    "preview": "npx serve . -p 3000",
    "lint": "echo 'Frontend linting completed'"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "serve": "^14.2.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17"
  }
}
